{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "koda",
  "version": "0.9.3-3",
  "identifier": "com.snnrve.koda",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Koda",
        "width": 800,
        "height": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' library-asset:; img-src 'self' library-asset: https: http: data:; media-src 'self' library-asset: https: http:; connect-src 'self' https: http: ws:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
